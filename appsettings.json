{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ReportingDb": "Data Source=.;Initial Catalog=ReportingPOC;Integrated Security=True;TrustServerCertificate=True"
  },
  "AWS": {
    "AccessKey": "",
    "SecretKey": "",
    "Region": "ap-southeast-1"
  },
  "ReportingRuntime": {
    "BucketName": "reportingpoc-dev",
    "AwsRegion": "ap-southeast-1",
    "HostAppId": "ReportingPOC",
    "TelerikStoragePrefix": "telerik/session-cache",
    "ClientSessionTimeout": 15,
    "ReportSharingTimeout": 10,
    "AllowLocalStorageInDevelopment": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TelerikPOC": "Debug"
    }
  }
}
