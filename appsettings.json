{
  "AllowedHosts": "*",
    "ConnectionStrings": {
        "TelerikConnectionString": "Data Source=.;Initial Catalog=ReportingPOC;Integrated Security=True;TrustServerCertificate=True"
    },

    "AWS": {
      "AccessKey": "YOUR_DEV_KEY",
      "SecretKey": "YOUR_DEV_SECRET",
      "Region": "ap-southeast-1",
      "BucketName": "reportingpoc-dev"
    },

    "telerikReporting": {
      "processing": {
        "resourceResolver": {
          "provider": "custom",
          "parameters": [
            {
              "name": "typeName",
              "value": "TelerikPOC.Resolvers.S3ResourceResolver, TelerikPOC"
            }
          ]
        }
      },
      "restReportService": {
        "hostAppId": "ReportingPOC",
        "clientSessionTimeout": 15,
        "reportSharingTimeout": 0,
        "exceptionsVerbosity": "detailed"
      }
    },

    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning",
        "TelerikPOC": "Debug"
      }
    }
  }





